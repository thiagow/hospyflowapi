generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String              @id @default(uuid())
  name         String
  subdomain    String              @unique
  logo         String?
  whatsapp     String?
  cnpj         String?
  planId       String
  status       TenantStatus        @default(ACTIVE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  activityLogs ActivityLog[]
  checklists   ChecklistTemplate[]
  feedbacks    Feedback[]
  requests     GuestRequest[]
  rooms        Room[]
  roomTypes    RoomType[]
  logs         SystemLog[]
  tasks        Task[]
  plan         Plan                @relation(fields: [planId], references: [id])
  users        User[]
}

model Plan {
  id           String       @id @default(uuid())
  name         String
  price        Float
  billingCycle BillingCycle @default(MONTHLY)
  maxUsers     Int
  maxRooms     Int
  features     String[]
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenants      Tenant[]
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String
  mobile        String
  password      String
  role          UserRole
  avatar        String?
  status        UserStatus     @default(ACTIVE)
  tenantId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cpf           String?
  whatsapp      String?
  roomId        String?
  guestCount    Int?
  checkinDate   DateTime?
  checkoutDate  DateTime?
  activityLogs  ActivityLog[]  @relation("UserActivityLogs")
  feedbacks     Feedback[]
  requests      GuestRequest[]
  logs          SystemLog[]
  assignedTasks    Task[]         @relation("AssignedTasks")
  assignedRequests GuestRequest[] @relation("AssignedRequests")
  openedRequests   GuestRequest[] @relation("CreatedRequests")
  room             Room?          @relation("GuestRoom", fields: [roomId], references: [id])
  tenant           Tenant?        @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
  @@unique([mobile, tenantId])
}

model RoomType {
  id          String   @id @default(uuid())
  name        String
  description String?
  capacity    Int
  price       Float
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rooms       Room[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Room {
  id        String         @id @default(uuid())
  number    String
  typeId    String
  status    RoomStatus     @default(AVAILABLE)
  floor     Int
  tenantId  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  feedbacks Feedback[]
  requests  GuestRequest[]
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  type      RoomType       @relation(fields: [typeId], references: [id])
  tasks     Task[]
  guests    User[]         @relation("GuestRoom")

  @@unique([number, tenantId])
}

model ChecklistTemplate {
  id        String                  @id @default(uuid())
  name      String
  tenantId  String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  tenant    Tenant                  @relation(fields: [tenantId], references: [id])
  items     ChecklistTemplateItem[]
}

model ChecklistTemplateItem {
  id         String            @id @default(uuid())
  text       String
  subtext    String?
  order      Int
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Task {
  id             String              @id @default(uuid())
  title          String
  description    String?
  roomId         String?
  assignedToId   String?
  status         TaskStatus          @default(PENDING)
  priority       TaskPriority        @default(MEDIUM)
  image          String?
  tenantId       String
  isDaily        Boolean             @default(false)
  createdAt      DateTime            @default(now())
  completedAt    DateTime?
  updatedAt      DateTime            @updatedAt
  assignedTo     User?               @relation("AssignedTasks", fields: [assignedToId], references: [id])
  room           Room?               @relation(fields: [roomId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  requestId      String?             @unique
  request        GuestRequest?       @relation(fields: [requestId], references: [id])
  checklistItems TaskChecklistItem[]
  photos         TaskPhoto[]
}

model TaskChecklistItem {
  id      String  @id @default(uuid())
  text    String
  subtext String?
  checked Boolean @default(false)
  order   Int
  taskId  String
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskPhoto {
  id        String   @id @default(uuid())
  url       String
  taskId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model GuestRequest {
  id          String        @id @default(uuid())
  guestId     String
  roomId      String
  type        RequestType
  description String?
  status      RequestStatus @default(PENDING)
  isUrgent    Boolean       @default(false)
  createdByUserId String?
  tenantId    String
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime      @updatedAt
  guest       User          @relation(fields: [guestId], references: [id])
  assignedTo  User?         @relation("AssignedRequests", fields: [assignedToId], references: [id])
  createdByUser User?       @relation("CreatedRequests", fields: [createdByUserId], references: [id])
  assignedToId String?
  room        Room          @relation(fields: [roomId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  task        Task?
}

model Feedback {
  id             String   @id @default(uuid())
  guestId        String
  roomId         String
  cleaningRating Int
  serviceRating  Int
  comment        String?
  tags           String[]
  tenantId       String
  createdAt      DateTime @default(now())
  guest          User     @relation(fields: [guestId], references: [id])
  room           Room     @relation(fields: [roomId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model SystemLog {
  id          String   @id @default(uuid())
  action      String
  description String
  userId      String?
  type        LogType  @default(INFO)
  tenantId    String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation("UserActivityLogs", fields: [userId], references: [id])

  @@index([tenantId])
}

enum UserRole {
  SAAS_ADMIN
  ADMIN
  RECEPTION
  STAFF
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  MAINTENANCE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum RequestType {
  LIMPEZA
  TOALHAS
  SERVICO_QUARTO
  MANUTENCAO
  OUTRO
}

enum RequestStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LogType {
  INFO
  WARNING
  ERROR
  ACTION
}
